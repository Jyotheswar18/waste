pipeline {
    agent any

    stages {

        stage('Clone Code') {
            steps {
                git 'https://github.com/Jyotheswar18/university-dept.git'
            }
        }

        stage('Build Docker Image') {
            steps {
                bat 'docker build -t university-app .'
            }
        }

        stage('Run Container') {
            steps {
                bat 'docker run -d -p 8082:80 university-app'
            }
        }

        stage('Deploy to Kubernetes') {
            steps {
                bat 'kubectl apply -f deployment.yaml'
                bat 'kubectl apply -f service.yaml'
            }
        }

    }
}

