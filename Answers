✅ PART 4: Docker Setup
📦 Dockerfile
FROM nginx:alpine
COPY . /usr/share/nginx/html
EXPOSE 80
Step 4: Build Docker Image
docker build -t university-app .
Step 5: Run Container
docker run -d -p 8081:80 university-app

👉 Open browser:

http://localhost:8081
✅ PART 5: Kubernetes Deployment
📄 deployment.yaml
apiVersion: apps/v1
kind: Deployment
metadata:
  name: university-deployment
spec:
  replicas: 2
  selector:
    matchLabels:
      app: university
  template:
    metadata:
      labels:
        app: university
    spec:
      containers:
      - name: university-container
        image: university-app
        ports:
        - containerPort: 80
📄 service.yaml
apiVersion: v1
kind: Service
metadata:
  name: university-service
spec:
  type: NodePort
  selector:
    app: university
  ports:
    - port: 80
      targetPort: 80
      nodePort: 30007
Step 6: Apply Kubernetes
kubectl apply -f deployment.yaml
kubectl apply -f service.yaml

👉 Access:

http://localhost:30007
✅ PART 6: Jenkins Pipeline
Step 7: Install Plugins
Docker Pipeline
Kubernetes CLI
Git
Step 8: Create Jenkins Pipeline Job
📄 Jenkinsfile
pipeline {
    agent any

    stages {

        stage('Clone') {
            steps {
                git 'https://github.com/your-username/university-dept.git'
            }
        }

        stage('Build Docker Image') {
            steps {
                bat 'docker build -t university-app .'
            }
        }

        stage('Run Container') {
            steps {
                bat 'docker run -d -p 8082:80 university-app'
            }
        }

        stage('Deploy to Kubernetes') {
            steps {
                bat 'kubectl apply -f deployment.yaml'
                bat 'kubectl apply -f service.yaml'
            }
        }
    }
}
